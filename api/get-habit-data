export default async function handler(req, res) {
  const { source_db_id, source_property } = req.query;
  if (!source_db_id || !source_property) {
    return res.status(400).json({ error: 'source_db_id, source_property required' });
  }

  const headers = {
    'Authorization': `Bearer ${process.env.NOTION_TOKEN}`,
    'Notion-Version': '2022-06-28',
    'Content-Type': 'application/json'
  };

  try {
    // 전체 별 개수 = 해당 multi-select 속성의 전체 옵션 수
    const dbRes = await fetch(`https://api.notion.com/v1/databases/${source_db_id}`, { headers });
    const db = await dbRes.json();
    const allOptions = db.properties[source_property]?.multi_select?.options?.map(o => o.name) || [];

    // 오늘(KST) 행 찾기 — 날짜 속성명이 '날짜'라고 가정
    const today = new Date().toLocaleDateString('sv-SE', { timeZone: 'Asia/Seoul' });
    const queryRes = await fetch(`https://api.notion.com/v1/databases/${source_db_id}/query`, {
      method: 'POST',
      headers,
      body: JSON.stringify({ filter: { property: '날짜', date: { equals: today } } })
    });
    const queryData = await queryRes.json();
    const page = queryData.results?.[0];

    const completedOptions = page
      ? page.properties[source_property]?.multi_select?.map(o => o.name) || []
      : [];

    res.status(200).json({
      total: allOptions.length,
      completed: completedOptions.length,
      items: allOptions.map(name => ({ name, done: completedOptions.includes(name) }))
    });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
}
